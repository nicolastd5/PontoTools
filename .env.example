# =============================================
# BANCO DE DADOS
# =============================================
DATABASE_URL=postgres://usuario:senha@localhost:5432/ponto_eletronico

# =============================================
# JWT
# =============================================
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=seu_segredo_jwt_aqui
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# =============================================
# ARMAZENAMENTO DE FOTOS
# local  = salva em disco (padrão para desenvolvimento)
# s3     = AWS S3 (produção)
# =============================================
STORAGE_DRIVER=local
PHOTOS_BASE_PATH=./storage/photos

# AWS S3 (apenas se STORAGE_DRIVER=s3)
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================
# SERVIDOR
# =============================================
PORT=3001
NODE_ENV=development

# =============================================
# CORS
# URLs permitidas para frontend web e pagina de status
# =============================================
CORS_ORIGIN=https://seu-dominio.com,https://www.seu-dominio.com,https://status.seu-dominio.com,http://localhost:5173

# =============================================
# RATE LIMITING
# =============================================
# Tentativas de login por IP a cada 15 minutos
RATE_LIMIT_LOGIN_MAX=5
# Batidas de ponto por usuário por minuto
RATE_LIMIT_CLOCK_MAX=10

# =============================================
# EMAIL (recuperação de senha)
# Use smtp.office365.com para Outlook/Hotmail
# =============================================
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=seu-email@exemplo.com
EMAIL_PASSWORD=sua_senha_de_app_aqui
EMAIL_FROM="Ponto Eletrônico <no-reply@exemplo.com>"

# URL base do frontend (usada no link do email de reset)
APP_URL=https://seu-dominio.com

# =============================================
# WEB PUSH (VAPID)
# Gere com: npx web-push generate-vapid-keys
# =============================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:seu-email@exemplo.com

# Chave pública exposta ao frontend (mesma que VAPID_PUBLIC_KEY)
# Adicione ao frontend/.env como:
# VITE_VAPID_PUBLIC_KEY=<valor de VAPID_PUBLIC_KEY>

# =============================================
# FIREBASE (FCM — push notifications mobile)
# Caminho para o arquivo de service account do Firebase Admin SDK
# =============================================
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
